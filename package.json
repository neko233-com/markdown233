{
  "name": "markdown233",
  "private": true,
  "version": "0.2.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "dev:native": "tauri dev",
    "build:native": "tauri build --config src-tauri/tauri.no-updater-artifacts.conf.json",
    "build:native:small": "tauri build --config src-tauri/tauri.no-updater-artifacts.conf.json",
    "build:native:windows": "tauri build --bundles nsis --config src-tauri/tauri.no-updater-artifacts.conf.json",
    "build:native:macos": "tauri build --bundles app,dmg --no-sign --config src-tauri/tauri.no-updater-artifacts.conf.json",
    "install:native": "powershell -ExecutionPolicy Bypass -File scripts/install.ps1",
    "release:windows": "powershell -ExecutionPolicy Bypass -File scripts/release.ps1",
    "release:signed:windows": "powershell -ExecutionPolicy Bypass -File scripts/release-signed.ps1",
    "e2e:screenshot": "node scripts/e2e-screenshot.mjs",
    "release:manifest": "node scripts/generate-updater-manifest.mjs"
  },
  "dependencies": {
    "@milkdown/core": "^7.6.2",
    "@milkdown/ctx": "^7.6.2",
    "@milkdown/preset-commonmark": "^7.6.2",
    "@milkdown/preset-gfm": "^7.6.2",
    "@milkdown/theme-nord": "^7.6.2",
    "@milkdown/utils": "^7.6.2",
    "@milkdown/plugin-listener": "^7.6.2",
    "@milkdown/plugin-history": "^7.6.2",
    "@milkdown/plugin-clipboard": "^7.6.2",
    "@milkdown/plugin-indent": "^7.6.2",
    "@milkdown/plugin-tooltip": "^7.6.2",
    "@milkdown/plugin-slash": "^7.6.2",
    "@prosemirror-adapter/core": "^0.2.6",
    "@prosemirror-adapter/lit": "^0.2.6",
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "@tauri-apps/plugin-fs": "2.5.1",
    "@tauri-apps/plugin-opener": "2.5.4",
    "@tauri-apps/plugin-process": "2.3.1",
    "@tauri-apps/plugin-updater": "2.10.1"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0",
    "@tauri-apps/cli": "2.11.3",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
